{
  "info": {
    "name": "CampusSync - Post Management Testing",
    "description": "Complete API testing collection for CampusSync Post Management System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{jwt_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080"
    },
    {
      "key": "jwt_token",
      "value": ""
    },
    {
      "key": "user_email",
      "value": "society@example.com"
    },
    {
      "key": "created_post_id",
      "value": ""
    },
    {
      "key": "uploaded_file_url",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "🔐 Authentication",
      "item": [
        {
          "name": "Register Society User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Society Test User\",\n  \"email\": \"{{user_email}}\",\n  \"password\": \"password123\",\n  \"role\": \"SOCIETY\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Verify Email (Use OTP from email)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{user_email}}\",\n  \"code\": \"123456\",\n  \"name\": \"Society Test User\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/verify?email={{user_email}}&code=123456&name=Society Test User",
              "host": ["{{base_url}}"],
              "path": ["auth", "verify"],
              "query": [
                {
                  "key": "email",
                  "value": "{{user_email}}"
                },
                {
                  "key": "code",
                  "value": "123456"
                },
                {
                  "key": "name",
                  "value": "Society Test User"
                }
              ]
            }
          }
        },
        {
          "name": "Login Society User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('jwt_token', response);",
                  "    console.log('JWT Token saved:', response);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{user_email}}\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "📷 File Upload",
      "item": [
        {
          "name": "Upload Post Media",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const fileUrl = pm.response.text();",
                  "    pm.collectionVariables.set('uploaded_file_url', fileUrl);",
                  "    console.log('File uploaded:', fileUrl);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/files/posts/upload",
              "host": ["{{base_url}}"],
              "path": ["files", "posts", "upload"]
            }
          }
        }
      ]
    },
    {
      "name": "📝 Post Management",
      "item": [
        {
          "name": "Create Post (Text Only)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const post = pm.response.json();",
                  "    pm.collectionVariables.set('created_post_id', post.id);",
                  "    console.log('Post created with ID:', post.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Welcome to our society! We're excited to announce our upcoming tech event. Stay tuned for more details! #SocietyLife #CampusEvents\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/posts",
              "host": ["{{base_url}}"],
              "path": ["posts"]
            }
          }
        },
        {
          "name": "Create Post (With Media)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Check out our new society banner! We're ready for an amazing semester ahead.\",\n  \"mediaUrl\": \"{{uploaded_file_url}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/posts",
              "host": ["{{base_url}}"],
              "path": ["posts"]
            }
          }
        },
        {
          "name": "Create Post (Linked to Event)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Don't miss our upcoming Tech Workshop! Register now through the events section.\",\n  \"eventId\": 1\n}"
            },
            "url": {
              "raw": "{{base_url}}/posts",
              "host": ["{{base_url}}"],
              "path": ["posts"]
            }
          }
        },
        {
          "name": "Get All Posts",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/posts",
              "host": ["{{base_url}}"],
              "path": ["posts"]
            }
          }
        },
        {
          "name": "Get Specific Post",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/posts/{{created_post_id}}",
              "host": ["{{base_url}}"],
              "path": ["posts", "{{created_post_id}}"]
            }
          }
        },
        {
          "name": "Get Posts by Author",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/posts/author/1",
              "host": ["{{base_url}}"],
              "path": ["posts", "author", "1"]
            }
          }
        },
        {
          "name": "Delete Post",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/posts/{{created_post_id}}",
              "host": ["{{base_url}}"],
              "path": ["posts", "{{created_post_id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "❌ Error Testing",
      "item": [
        {
          "name": "Create Post Without Auth (Should Fail)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "",
                "disabled": true
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"This should fail without authentication\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/posts",
              "host": ["{{base_url}}"],
              "path": ["posts"]
            }
          }
        },
        {
          "name": "Create Post with Empty Content (Should Fail)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/posts",
              "host": ["{{base_url}}"],
              "path": ["posts"]
            }
          }
        },
        {
          "name": "Create Post with Invalid Event ID (Should Fail)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"This references a non-existent event\",\n  \"eventId\": 99999\n}"
            },
            "url": {
              "raw": "{{base_url}}/posts",
              "host": ["{{base_url}}"],
              "path": ["posts"]
            }
          }
        },
        {
          "name": "Get Non-existent Post (Should Fail)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/posts/99999",
              "host": ["{{base_url}}"],
              "path": ["posts", "99999"]
            }
          }
        }
      ]
    },
    {
      "name": "🔄 Workflow Tests",
      "item": [
        {
          "name": "Complete Post Creation Workflow",
          "item": [
            {
              "name": "1. Register User",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"Workflow Test User\",\n  \"email\": \"workflow@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"DEPARTMENT\"\n}"
                },
                "url": {
                  "raw": "{{base_url}}/auth/register",
                  "host": ["{{base_url}}"],
                  "path": ["auth", "register"]
                }
              }
            },
            {
              "name": "2. Verify Email",
              "request": {
                "method": "POST",
                "header": [],
                "url": {
                  "raw": "{{base_url}}/auth/verify?email=workflow@example.com&code=123456&name=Workflow Test User",
                  "host": ["{{base_url}}"],
                  "path": ["auth", "verify"],
                  "query": [
                    {
                      "key": "email",
                      "value": "workflow@example.com"
                    },
                    {
                      "key": "code",
                      "value": "123456"
                    },
                    {
                      "key": "name",
                      "value": "Workflow Test User"
                    }
                  ]
                }
              }
            },
            {
              "name": "3. Login",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "if (pm.response.code === 200) {",
                      "    const token = pm.response.json();",
                      "    pm.collectionVariables.set('jwt_token', token);",
                      "}"
                    ]
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"workflow@example.com\",\n  \"password\": \"password123\"\n}"
                },
                "url": {
                  "raw": "{{base_url}}/auth/login",
                  "host": ["{{base_url}}"],
                  "path": ["auth", "login"]
                }
              }
            },
            {
              "name": "4. Create Post",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "if (pm.response.code === 200) {",
                      "    const post = pm.response.json();",
                      "    pm.collectionVariables.set('created_post_id', post.id);",
                      "}"
                    ]
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"content\": \"🎓 Department Announcement: Classes will resume next week. All students please check the updated schedule on the portal.\"\n}"
                },
                "url": {
                  "raw": "{{base_url}}/posts",
                  "host": ["{{base_url}}"],
                  "path": ["posts"]
                }
              }
            },
            {
              "name": "5. View Created Post",
              "request": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{base_url}}/posts/{{created_post_id}}",
                  "host": ["{{base_url}}"],
                  "path": ["posts", "{{created_post_id}}"]
                }
              }
            },
            {
              "name": "6. View All Posts",
              "request": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{base_url}}/posts",
                  "host": ["{{base_url}}"],
                  "path": ["posts"]
                }
              }
            }
          ]
        }
      ]
    }
  ]
}