{
  "info": {
    "name": "CampusSync - Event Management & Analytics Testing (Task 3.1 + 3.2)",
    "description": "Postman collection for advanced event management, event status/category/search, event analytics, and dashboard analytics.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080"
    },
    {
      "key": "manager_jwt",
      "value": ""
    },
    {
      "key": "admin_jwt",
      "value": ""
    },
    {
      "key": "event_id",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "0) Setup",
      "item": [
        {
          "name": "How to use this collection",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/events"
            },
            "description": "Set `manager_jwt` with a SOCIETY/DEPARTMENT/ADMIN token and `admin_jwt` with an ADMIN token before running protected requests."
          }
        }
      ]
    },
    {
      "name": "1) Task 3.1 - Event Management",
      "item": [
        {
          "name": "Create Event (DRAFT)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "pm.test('Response has id', function () { pm.expect(body.id).to.exist; });",
                  "pm.collectionVariables.set('event_id', body.id);"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{manager_jwt}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Task 3.1 Placement Drive\",\n  \"description\": \"Campus placement orientation and resume clinic.\",\n  \"venue\": \"Seminar Hall\",\n  \"date\": \"2026-06-20T10:00:00\",\n  \"type\": \"PLACEMENT\",\n  \"status\": \"DRAFT\",\n  \"paid\": false,\n  \"price\": 0.0,\n  \"imageUrl\": \"https://example.com/event-banner.png\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/events",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "events"
              ]
            }
          }
        },
        {
          "name": "Update Event",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "pm.test('Title updated', function () { pm.expect(body.title).to.eql('Task 3.1 Placement Drive - Updated'); });"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{manager_jwt}}",
                  "type": "string"
                }
              ]
            },
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Task 3.1 Placement Drive - Updated\",\n  \"description\": \"Updated details with interview prep workshop.\",\n  \"venue\": \"Main Auditorium\",\n  \"date\": \"2026-06-21T11:00:00\",\n  \"type\": \"PLACEMENT\",\n  \"status\": \"DRAFT\",\n  \"paid\": true,\n  \"price\": 149.0,\n  \"imageUrl\": \"https://example.com/event-updated.png\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/events/{{event_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "events",
                "{{event_id}}"
              ]
            }
          }
        },
        {
          "name": "Publish Event Status",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "pm.test('Status changed to PUBLISHED', function () { pm.expect(body.status).to.eql('PUBLISHED'); });"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{manager_jwt}}",
                  "type": "string"
                }
              ]
            },
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{base_url}}/events/{{event_id}}/status?status=PUBLISHED",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "events",
                "{{event_id}}",
                "status"
              ],
              "query": [
                {
                  "key": "status",
                  "value": "PUBLISHED"
                }
              ]
            }
          }
        },
        {
          "name": "Get Public Events (Published Only)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "const arr = pm.response.json();",
                  "pm.test('Response is array', function () { pm.expect(Array.isArray(arr)).to.eql(true); });"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/events",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "events"
              ]
            }
          }
        },
        {
          "name": "Search Events by Keyword + Type + Status",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "const arr = pm.response.json();",
                  "pm.test('Response is array', function () { pm.expect(Array.isArray(arr)).to.eql(true); });"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/events/search?keyword=placement&type=PLACEMENT&status=PUBLISHED",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "events",
                "search"
              ],
              "query": [
                {
                  "key": "keyword",
                  "value": "placement"
                },
                {
                  "key": "type",
                  "value": "PLACEMENT"
                },
                {
                  "key": "status",
                  "value": "PUBLISHED"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "2) Task 3.2 - Event Analytics",
      "item": [
        {
          "name": "Get Event By Id (increments views)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "pm.test('Views count exists', function () { pm.expect(body.viewsCount).to.not.equal(undefined); });"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/events/{{event_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "events",
                "{{event_id}}"
              ]
            }
          }
        },
        {
          "name": "Get Event By Id Again (views should increase)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/events/{{event_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "events",
                "{{event_id}}"
              ]
            }
          }
        },
        {
          "name": "Get Event Analytics",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "pm.test('Analytics fields present', function () {",
                  "  pm.expect(body).to.have.property('views');",
                  "  pm.expect(body).to.have.property('totalRegistrations');",
                  "  pm.expect(body).to.have.property('activeRegistrations');",
                  "  pm.expect(body).to.have.property('cancelledRegistrations');",
                  "  pm.expect(body).to.have.property('registrationConversionRate');",
                  "  pm.expect(body).to.have.property('engagementScore');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{manager_jwt}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/events/{{event_id}}/analytics",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "events",
                "{{event_id}}",
                "analytics"
              ]
            }
          }
        },
        {
          "name": "Get Dashboard Analytics (ADMIN)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "pm.test('Dashboard fields present', function () {",
                  "  pm.expect(body).to.have.property('totalUsers');",
                  "  pm.expect(body).to.have.property('totalEvents');",
                  "  pm.expect(body).to.have.property('totalRegistrations');",
                  "  pm.expect(body).to.have.property('publishedEvents');",
                  "  pm.expect(body).to.have.property('cancelledEvents');",
                  "  pm.expect(body).to.have.property('totalEventViews');",
                  "  pm.expect(body).to.have.property('averageRegistrationsPerEvent');",
                  "  pm.expect(body).to.have.property('eventEngagementRate');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{admin_jwt}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/dashboard",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "dashboard"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "3) Optional Cleanup",
      "item": [
        {
          "name": "Delete Event",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{manager_jwt}}",
                  "type": "string"
                }
              ]
            },
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/events/{{event_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "events",
                "{{event_id}}"
              ]
            }
          }
        }
      ]
    }
  ]
}
