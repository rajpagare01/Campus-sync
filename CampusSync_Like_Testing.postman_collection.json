{
  "info": {
    "name": "CampusSync - Like System Testing",
    "description": "Complete API testing collection for CampusSync Like System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{jwt_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080"
    },
    {
      "key": "jwt_token",
      "value": ""
    },
    {
      "key": "society_email",
      "value": "society@example.com"
    },
    {
      "key": "student_email",
      "value": "student@example.com"
    },
    {
      "key": "created_post_id",
      "value": ""
    },
    {
      "key": "like_id",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "🔐 Setup Users",
      "item": [
        {
          "name": "Register Society User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Society Test User\",\n  \"email\": \"{{society_email}}\",\n  \"password\": \"password123\",\n  \"role\": \"SOCIETY\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Verify Society Email",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/auth/verify?email={{society_email}}&code=123456&name=Society%20Test%20User",
              "host": ["{{base_url}}"],
              "path": ["auth", "verify"],
              "query": [
                {
                  "key": "email",
                  "value": "{{society_email}}"
                },
                {
                  "key": "code",
                  "value": "123456"
                },
                {
                  "key": "name",
                  "value": "Society Test User"
                }
              ]
            }
          }
        },
        {
          "name": "Login Society User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('jwt_token', response);",
                  "    console.log('Society JWT Token saved:', response);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{society_email}}\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Register Student User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Student Test User\",\n  \"email\": \"{{student_email}}\",\n  \"password\": \"password123\",\n  \"role\": \"STUDENT\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Verify Student Email",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/auth/verify?email={{student_email}}&code=123456&name=Student%20Test%20User",
              "host": ["{{base_url}}"],
              "path": ["auth", "verify"],
              "query": [
                {
                  "key": "email",
                  "value": "{{student_email}}"
                },
                {
                  "key": "code",
                  "value": "123456"
                },
                {
                  "key": "name",
                  "value": "Student Test User"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "📝 Create Test Post",
      "item": [
        {
          "name": "Create Post for Like Testing",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const post = pm.response.json();",
                  "    pm.collectionVariables.set('created_post_id', post.id);",
                  "    console.log('Post created with ID:', post.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"This is a test post for like functionality! 👍 #LikeMe\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/posts",
              "host": ["{{base_url}}"],
              "path": ["posts"]
            }
          }
        }
      ]
    },
    {
      "name": "❤️ Like System Testing",
      "item": [
        {
          "name": "Like Post (First Time)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const like = pm.response.json();",
                  "    if (like) {",
                  "        pm.collectionVariables.set('like_id', like.id);",
                  "        console.log('Post liked! Like ID:', like.id);",
                  "    } else {",
                  "        console.log('Post unliked!');",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/posts/{{created_post_id}}/like",
              "host": ["{{base_url}}"],
              "path": ["posts", "{{created_post_id}}", "like"]
            }
          }
        },
        {
          "name": "Check Post Shows Like Count",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/posts/{{created_post_id}}",
              "host": ["{{base_url}}"],
              "path": ["posts", "{{created_post_id}}"]
            }
          }
        },
        {
          "name": "Get Likes for Post",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/posts/{{created_post_id}}/likes",
              "host": ["{{base_url}}"],
              "path": ["posts", "{{created_post_id}}", "likes"]
            }
          }
        },
        {
          "name": "Unlike Post (Second Time)",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/posts/{{created_post_id}}/like",
              "host": ["{{base_url}}"],
              "path": ["posts", "{{created_post_id}}", "like"]
            }
          }
        },
        {
          "name": "Verify Unlike Worked",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/posts/{{created_post_id}}",
              "host": ["{{base_url}}"],
              "path": ["posts", "{{created_post_id}}"]
            }
          }
        },
        {
          "name": "Get User's Liked Posts",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/posts/likes/user",
              "host": ["{{base_url}}"],
              "path": ["posts", "likes", "user"]
            }
          }
        }
      ]
    },
    {
      "name": "🔄 Multiple Users Like Testing",
      "item": [
        {
          "name": "Login as Student",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const token = pm.response.json();",
                  "    pm.collectionVariables.set('jwt_token', token);",
                  "    console.log('Switched to Student JWT Token');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{student_email}}\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Student Likes Post",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/posts/{{created_post_id}}/like",
              "host": ["{{base_url}}"],
              "path": ["posts", "{{created_post_id}}", "like"]
            }
          }
        },
        {
          "name": "Check Multiple Likes",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/posts/{{created_post_id}}/likes",
              "host": ["{{base_url}}"],
              "path": ["posts", "{{created_post_id}}", "likes"]
            }
          }
        },
        {
          "name": "Student Unlikes Post",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/posts/{{created_post_id}}/like",
              "host": ["{{base_url}}"],
              "path": ["posts", "{{created_post_id}}", "like"]
            }
          }
        }
      ]
    },
    {
      "name": "❌ Error Testing",
      "item": [
        {
          "name": "Like Non-existent Post",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/posts/99999/like",
              "host": ["{{base_url}}"],
              "path": ["posts", "99999", "like"]
            }
          }
        },
        {
          "name": "Get Likes for Non-existent Post",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/posts/99999/likes",
              "host": ["{{base_url}}"],
              "path": ["posts", "99999", "likes"]
            }
          }
        },
        {
          "name": "Like Post Without Auth",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "",
                "disabled": true
              }
            ],
            "url": {
              "raw": "{{base_url}}/posts/{{created_post_id}}/like",
              "host": ["{{base_url}}"],
              "path": ["posts", "{{created_post_id}}", "like"]
            }
          }
        }
      ]
    }
  ]
}