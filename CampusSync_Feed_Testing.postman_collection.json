              "path": ["feed"],
              "query": [
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "10"
                },
                {
                  "key": "filter",
                  "value": "events"
                },
                {
                  "key": "sort",
                  "value": "date"
                }
              ]
            }
          }
        },
        {
          "name": "Sort by Engagement",
          "request": {
            "method": "GET",
