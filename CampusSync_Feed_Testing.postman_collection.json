                },
                {
                  "key": "filter",
                  "value": "all"
                },
                {
                  "key": "sort",
                  "value": "date"
                }
              ]
            }
          }
        },
        {
          "name": "Get Feed Statistics",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/feed/stats",
              "host": ["{{base_url}}"],
              "path": ["feed", "stats"]
            }
          }
        }
      ]
    },
    {
      "name": "❤️ Test Engagement Scoring",
      "item": [
        {
          "name": "Like a Post to Test Engagement",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/posts/1/like",
              "host": ["{{base_url}}"],
              "path": ["posts", "1", "like"]
            }
          }
        },
        {
          "name": "Check Feed with Engagement Sort",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/feed?page=0&size=10&filter=all&sort=engagement",
              "host": ["{{base_url}}"],
