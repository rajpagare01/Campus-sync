        },
        {
          "name": "Pagination Test (Page 1)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/feed?page=1&size=5&filter=all&sort=date",
              "host": ["{{base_url}}"],
              "path": ["feed"],
              "query": [
                {
                  "key": "page",
