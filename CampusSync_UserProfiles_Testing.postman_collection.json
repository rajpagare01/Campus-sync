{
  "info": {
    "name": "CampusSync User Profiles Testing",
    "description": "Test collection for Task 4.1 - User Profiles API endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Get Current User's Profile",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/users/profile",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "users",
            "profile"
          ]
        },
        "description": "Get the authenticated user's profile with all statistics"
      },
      "response": []
    },
    {
      "name": "2. Get Public User Profile by ID",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/users/1/profile",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "users",
            "1",
            "profile"
          ]
        },
        "description": "Get any user's public profile (no authentication required)"
      },
      "response": []
    },
    {
      "name": "3. Update User Profile",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"John Doe Updated\",\n  \"bio\": \"Computer Science student passionate about web development and open source\",\n  \"profilePictureUrl\": \"https://example.com/images/profile-john-updated.jpg\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/users/profile",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "users",
            "profile"
          ]
        },
        "description": "Update the authenticated user's profile information"
      },
      "response": []
    },
    {
      "name": "4. Update Profile Name Only",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Jane Doe\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/users/profile",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "users",
            "profile"
          ]
        },
        "description": "Update only the user's name (partial update)"
      },
      "response": []
    },
    {
      "name": "5. Update Profile Bio Only",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"bio\": \"Updated bio: Event organizer and community enthusiast\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/users/profile",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "users",
            "profile"
          ]
        },
        "description": "Update only the user's bio"
      },
      "response": []
    },
    {
      "name": "6. Update Profile Picture",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/users/profile/picture?pictureUrl=https://example.com/images/new-profile-pic.jpg",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "users",
            "profile",
            "picture"
          ],
          "query": [
            {
              "key": "pictureUrl",
              "value": "https://example.com/images/new-profile-pic.jpg"
            }
          ]
        },
        "description": "Update the user's profile picture URL"
      },
      "response": []
    },
    {
      "name": "7. Get Current User's Activity",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/users/activity",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "users",
            "activity"
          ]
        },
        "description": "Get the authenticated user's activity history (posts, comments, likes, registrations)"
      },
      "response": []
    },
    {
      "name": "8. Get User's Activity by ID",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/users/1/activity",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "users",
            "1",
            "activity"
          ]
        },
        "description": "Get any user's activity history (public view)"
      },
      "response": []
    },
    {
      "name": "9. Get Current User's Statistics",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/users/stats/my-stats",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "users",
            "stats",
            "my-stats"
          ]
        },
        "description": "Get the authenticated user's statistics summary"
      },
      "response": []
    },
    {
      "name": "10. Get User's Statistics by ID",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/users/1/stats",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "users",
            "1",
            "stats"
          ]
        },
        "description": "Get any user's statistics summary (post count, likes, comments, registrations)"
      },
      "response": []
    },
    {
      "name": "Authentication - Register User",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"testuser@example.com\",\n  \"password\": \"password123\",\n  \"name\": \"Test User\",\n  \"role\": \"STUDENT\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/auth/register",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "auth",
            "register"
          ]
        },
        "description": "Register a new user (for testing)"
      },
      "response": []
    },
    {
      "name": "Authentication - Verify Email",
      "request": {
        "method": "POST",
        "url": {
          "raw": "{{base_url}}/auth/verify?email=testuser@example.com&code=123456&name=Test User",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "auth",
            "verify"
          ],
          "query": [
            {
              "key": "email",
              "value": "testuser@example.com"
            },
            {
              "key": "code",
              "value": "123456"
            },
            {
              "key": "name",
              "value": "Test User"
            }
          ]
        },
        "description": "Verify email with OTP (for testing)"
      },
      "response": []
    },
    {
      "name": "Authentication - Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"testuser@example.com\",\n  \"password\": \"password123\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/auth/login",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "auth",
            "login"
          ]
        },
        "description": "Login and get JWT token (copy to {{jwt_token}} variable)"
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "jwt_token",
      "value": "",
      "type": "string"
    }
  ]
}
