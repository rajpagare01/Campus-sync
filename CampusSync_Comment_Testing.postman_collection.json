{
  "info": {
    "name": "CampusSync - Comment System Testing",
    "description": "Complete API testing collection for CampusSync Comment System with threaded replies",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{jwt_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080"
    },
    {
      "key": "jwt_token",
      "value": ""
    },
    {
      "key": "society_email",
      "value": "society@example.com"
    },
    {
      "key": "student_email",
      "value": "student@example.com"
    },
    {
      "key": "created_post_id",
      "value": ""
    },
    {
      "key": "comment_id",
      "value": ""
    },
    {
      "key": "reply_id",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "🔐 Setup Test Users & Post",
      "item": [
        {
          "name": "Register Society User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Society Test User\",\n  \"email\": \"{{society_email}}\",\n  \"password\": \"password123\",\n  \"role\": \"SOCIETY\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Verify Society Email",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/auth/verify?email={{society_email}}&code=123456&name=Society%20Test%20User",
              "host": ["{{base_url}}"],
              "path": ["auth", "verify"],
              "query": [
                {
                  "key": "email",
                  "value": "{{society_email}}"
                },
                {
                  "key": "code",
                  "value": "123456"
                },
                {
                  "key": "name",
                  "value": "Society Test User"
                }
              ]
            }
          }
        },
        {
          "name": "Login Society User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('jwt_token', response);",
                  "    console.log('Society JWT Token saved');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{society_email}}\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Register Student User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Student Test User\",\n  \"email\": \"{{student_email}}\",\n  \"password\": \"password123\",\n  \"role\": \"STUDENT\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Verify Student Email",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/auth/verify?email={{student_email}}&code=123456&name=Student%20Test%20User",
              "host": ["{{base_url}}"],
              "path": ["auth", "verify"],
              "query": [
                {
                  "key": "email",
                  "value": "{{student_email}}"
                },
                {
                  "key": "code",
                  "value": "123456"
                },
                {
                  "key": "name",
                  "value": "Student Test User"
                }
              ]
            }
          }
        },
        {
          "name": "Create Test Post",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const post = pm.response.json();",
                  "    pm.collectionVariables.set('created_post_id', post.id);",
                  "    console.log('Post created with ID:', post.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"This is a test post for comment functionality! What are your thoughts? 💭 #Discussion\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/posts",
              "host": ["{{base_url}}"],
              "path": ["posts"]
            }
          }
        }
      ]
    },
    {
      "name": "💬 Comment Management",
      "item": [
        {
          "name": "Add First Comment",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const comment = pm.response.json();",
                  "    pm.collectionVariables.set('comment_id', comment.id);",
                  "    console.log('Comment created with ID:', comment.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Great post! I'm really excited about this initiative. When will more details be available?\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/posts/{{created_post_id}}/comments",
              "host": ["{{base_url}}"],
              "path": ["posts", "{{created_post_id}}", "comments"]
            }
          }
        },
        {
          "name": "Add Second Comment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"This sounds amazing! Count me in for the planning committee. 📝\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/posts/{{created_post_id}}/comments",
              "host": ["{{base_url}}"],
              "path": ["posts", "{{created_post_id}}", "comments"]
            }
          }
        },
        {
          "name": "Get All Comments (Threaded)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/posts/{{created_post_id}}/comments",
              "host": ["{{base_url}}"],
              "path": ["posts", "{{created_post_id}}", "comments"]
            }
          }
        },
        {
          "name": "Check Post Comment Count",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/posts/{{created_post_id}}",
              "host": ["{{base_url}}"],
              "path": ["posts", "{{created_post_id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "↩️ Reply System",
      "item": [
        {
          "name": "Add Reply to First Comment",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const reply = pm.response.json();",
                  "    pm.collectionVariables.set('reply_id', reply.id);",
                  "    console.log('Reply created with ID:', reply.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"@Society Test User - We'll be sharing more details in our next meeting. Stay tuned! 📅\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/posts/comments/{{comment_id}}/replies",
              "host": ["{{base_url}}"],
              "path": ["posts", "comments", "{{comment_id}}", "replies"]
            }
          }
        },
        {
          "name": "Add Another Reply",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Thanks for the quick response! Looking forward to it. 🚀\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/posts/comments/{{comment_id}}/replies",
              "host": ["{{base_url}}"],
              "path": ["posts", "comments", "{{comment_id}}", "replies"]
            }
          }
        },
        {
          "name": "Get Replies for Comment",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/posts/comments/{{comment_id}}/replies",
              "host": ["{{base_url}}"],
              "path": ["posts", "comments", "{{comment_id}}", "replies"]
            }
          }
        },
        {
          "name": "Get Full Threaded Comments",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/posts/{{created_post_id}}/comments",
              "host": ["{{base_url}}"],
              "path": ["posts", "{{created_post_id}}", "comments"]
            }
          }
        }
      ]
    },
    {
      "name": "✏️ Comment Editing",
      "item": [
        {
          "name": "Update Comment Content",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"[EDITED] Great post! I'm really excited about this initiative. When will more details be available? 📝\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/posts/comments/{{comment_id}}",
              "host": ["{{base_url}}"],
              "path": ["posts", "comments", "{{comment_id}}"]
            }
          }
        },
        {
          "name": "Verify Comment Update",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/posts/{{created_post_id}}/comments",
              "host": ["{{base_url}}"],
              "path": ["posts", "{{created_post_id}}", "comments"]
            }
          }
        }
      ]
    },
    {
      "name": "🗑️ Comment Deletion",
      "item": [
        {
          "name": "Delete Reply First",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/posts/comments/{{reply_id}}",
              "host": ["{{base_url}}"],
              "path": ["posts", "comments", "{{reply_id}}"]
            }
          }
        },
        {
          "name": "Delete Comment with Replies (Should Fail)",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/posts/comments/{{comment_id}}",
              "host": ["{{base_url}}"],
              "path": ["posts", "comments", "{{comment_id}}"]
            }
          }
        },
        {
          "name": "Delete Remaining Reply",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/posts/comments/4",
              "host": ["{{base_url}}"],
              "path": ["posts", "comments", "4"]
            }
          }
        },
        {
          "name": "Delete Comment (Now Should Work)",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/posts/comments/{{comment_id}}",
              "host": ["{{base_url}}"],
              "path": ["posts", "comments", "{{comment_id}}"]
            }
          }
        },
        {
          "name": "Verify Comments Deleted",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/posts/{{created_post_id}}/comments",
              "host": ["{{base_url}}"],
              "path": ["posts", "{{created_post_id}}", "comments"]
            }
          }
        }
      ]
    },
    {
      "name": "❌ Error Testing",
      "item": [
        {
          "name": "Add Comment to Non-existent Post",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"This should fail\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/posts/99999/comments",
              "host": ["{{base_url}}"],
              "path": ["posts", "99999", "comments"]
            }
          }
        },
        {
          "name": "Add Empty Comment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/posts/{{created_post_id}}/comments",
              "host": ["{{base_url}}"],
              "path": ["posts", "{{created_post_id}}", "comments"]
            }
          }
        },
        {
          "name": "Reply to Non-existent Comment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"This should fail\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/posts/comments/99999/replies",
              "host": ["{{base_url}}"],
              "path": ["posts", "comments", "99999", "replies"]
            }
          }
        },
        {
          "name": "Update Other User's Comment (Should Fail)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Trying to edit someone else's comment\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/posts/comments/2",
              "host": ["{{base_url}}"],
              "path": ["posts", "comments", "2"]
            }
          }
        },
        {
          "name": "Add Comment Without Auth",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "",
                "disabled": true
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"This should fail without auth\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/posts/{{created_post_id}}/comments",
              "host": ["{{base_url}}"],
              "path": ["posts", "{{created_post_id}}", "comments"]
            }
          }
        }
      ]
    }
  ]
}