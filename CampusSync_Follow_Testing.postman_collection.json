{
  "info": {
    "name": "CampusSync_Follow_Testing",
    "description": "API testing collection for User Following System in CampusSync",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Follow User",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/follow/follow/{{target_user_id}}",
          "host": ["{{base_url}}"],
          "path": ["api", "follow", "follow", "{{target_user_id}}"]
        },
        "description": "Follow a user by their ID"
      }
    },
    {
      "name": "Unfollow User",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/follow/unfollow/{{target_user_id}}",
          "host": ["{{base_url}}"],
          "path": ["api", "follow", "unfollow", "{{target_user_id}}"]
        },
        "description": "Unfollow a user by their ID"
      }
    },
    {
      "name": "Check if Following",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/follow/is-following/{{target_user_id}}",
          "host": ["{{base_url}}"],
          "path": ["api", "follow", "is-following", "{{target_user_id}}"]
        },
        "description": "Check if current user is following the target user"
      }
    },
    {
      "name": "Get Follow Stats",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/follow/stats/{{user_id}}",
          "host": ["{{base_url}}"],
          "path": ["api", "follow", "stats", "{{user_id}}"]
        },
        "description": "Get follow statistics for a user (followers count, following count, mutual status)"
      }
    },
    {
      "name": "Get Followers",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/follow/followers/{{user_id}}?page=0&size=20",
          "host": ["{{base_url}}"],
          "path": ["api", "follow", "followers", "{{user_id}}"],
          "query": [
            {
              "key": "page",
              "value": "0"
            },
            {
              "key": "size",
              "value": "20"
            }
          ]
        },
        "description": "Get paginated list of followers for a user"
      }
    },
    {
      "name": "Get Following",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/follow/following/{{user_id}}?page=0&size=20",
          "host": ["{{base_url}}"],
          "path": ["api", "follow", "following", "{{user_id}}"],
          "query": [
            {
              "key": "page",
              "value": "0"
            },
            {
              "key": "size",
              "value": "20"
            }
          ]
        },
        "description": "Get paginated list of users that a user is following"
      }
    },
    {
      "name": "Get Recommended Users",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/follow/recommendations?page=0&size=20",
          "host": ["{{base_url}}"],
          "path": ["api", "follow", "recommendations"],
          "query": [
            {
              "key": "page",
              "value": "0"
            },
            {
              "key": "size",
              "value": "20"
            }
          ]
        },
        "description": "Get recommended users to follow based on mutual connections"
      }
    },
    {
      "name": "Get Mutual Follows",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/follow/mutual",
          "host": ["{{base_url}}"],
          "path": ["api", "follow", "mutual"]
        },
        "description": "Get list of mutual follows (users who follow each other)"
      }
    },
    {
      "name": "Get Follower Users (for Profile)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/follow/followers/users/{{user_id}}?page=0&size=20",
          "host": ["{{base_url}}"],
          "path": ["api", "follow", "followers", "users", "{{user_id}}"],
          "query": [
            {
              "key": "page",
              "value": "0"
            },
            {
              "key": "size",
              "value": "20"
            }
          ]
        },
        "description": "Get paginated list of follower users for profile display"
      }
    },
    {
      "name": "Get Following Users (for Profile)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/follow/following/users/{{user_id}}?page=0&size=20",
          "host": ["{{base_url}}"],
          "path": ["api", "follow", "following", "users", "{{user_id}}"],
          "query": [
            {
              "key": "page",
              "value": "0"
            },
            {
              "key": "size",
              "value": "20"
            }
          ]
        },
        "description": "Get paginated list of following users for profile display"
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080"
    },
    {
      "key": "jwt_token",
      "value": ""
    },
    {
      "key": "target_user_id",
      "value": "2"
    },
    {
      "key": "user_id",
      "value": "1"
    }
  ]
}